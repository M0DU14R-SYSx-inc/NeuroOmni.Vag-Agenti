<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="?attr/colorControlNormal">

    <!-- Cogwheel (upper-left): gear ring + hub -->
    <group>
        <!-- gear teeth as a thick dashed-look ring approximated by a notched circle -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M8,1.2
                l1.0,1.9 l2.1,-0.3 l0.4,2.1 l1.9,1.0 l-1.0,1.9 l1.0,1.9 l-1.9,1.0 l-0.4,2.1 l-2.1,-0.3 l-1.0,1.9 l-1.0,-1.9 l-2.1,0.3 l-0.4,-2.1 l-1.9,-1.0 l1.0,-1.9 l-1.0,-1.9 l1.9,-1.0 l0.4,-2.1 l2.1,0.3 z" />
        <!-- hub hole -->
        <path
            android:fillColor="#0D1B26"
            android:pathData="M8,5.1 m-2.4,0 a2.4,2.4 0 1,0 4.8,0 a2.4,2.4 0 1,0 -4.8,0" />
    </group>

    <!-- RPM gauge (lower-right): dial arc + needle + tick marks -->
    <group>
        <!-- gauge face -->
        <path
            android:fillColor="#22D3EE"
            android:pathData="M16,13 m-6.6,0 a6.6,6.6 0 1,0 13.2,0 a6.6,6.6 0 1,0 -13.2,0" />
        <path
            android:fillColor="#0D1B26"
            android:pathData="M16,13 m-5.2,0 a5.2,5.2 0 1,0 10.4,0 a5.2,5.2 0 1,0 -10.4,0" />
        <!-- tick marks around the dial -->
        <path android:strokeColor="#7DE9F5" android:strokeWidth="0.8" android:strokeLineCap="round" android:pathData="M11.4,10.2 l0.9,0.7" />
        <path android:strokeColor="#7DE9F5" android:strokeWidth="0.8" android:strokeLineCap="round" android:pathData="M16,8.4 v1.1" />
        <path android:strokeColor="#7DE9F5" android:strokeWidth="0.8" android:strokeLineCap="round" android:pathData="M20.6,10.2 l-0.9,0.7" />
        <path android:strokeColor="#FF5A6E" android:strokeWidth="0.8" android:strokeLineCap="round" android:pathData="M20.8,13.6 l-1.1,0.2" />
        <!-- needle pointing to high RPM (red zone, upper-right) -->
        <path
            android:strokeColor="#FFFFFF"
            android:strokeWidth="1.3"
            android:strokeLineCap="round"
            android:pathData="M16,13 L19.2,10.6" />
        <!-- needle pivot -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M16,13 m-1.1,0 a1.1,1.1 0 1,0 2.2,0 a1.1,1.1 0 1,0 -2.2,0" />
    </group>
</vector>
